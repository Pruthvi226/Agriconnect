# ── Default: normalize line endings to LF in repo, checkout as-is
* text=auto

# ── Shell scripts MUST be LF in the Docker Linux container
*.sh text eol=lf

# ── Java / XML / properties / YAML: normalize to LF
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
Dockerfile text eol=lf

# ── Binaries: never touch line endings
*.war binary
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
