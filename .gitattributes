# Default: normalize line endings in the repository.
* text=auto

# Shell scripts must stay LF for Linux/Docker containers.
*.sh text eol=lf

# Source and configuration files.
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
Dockerfile text eol=lf

# Binary files.
*.war binary
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
