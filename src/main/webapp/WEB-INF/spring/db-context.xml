<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:tx="http://www.springframework.org/schema/tx"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/tx http://www.springframework.org/schema/tx/spring-tx.xsd
           http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd">

    <!-- HikariCP DataSource bean reading application properties / env vars -->
    <bean id="dataSource" class="com.zaxxer.hikari.HikariDataSource" destroy-method="close">
        <property name="driverClassName" value="${spring.datasource.driver-class-name:${jdbc.driverClassName:com.mysql.cj.jdbc.Driver}}" />
        <property name="jdbcUrl" value="${spring.datasource.url:${jdbc.url:jdbc:mysql://localhost:3306/agriconnect?useSSL=false&amp;allowPublicKeyRetrieval=true&amp;serverTimezone=UTC}}" />
        <property name="username" value="${spring.datasource.username:${jdbc.username:agriconnect}}" />
        <property name="password" value="${spring.datasource.password:${jdbc.password:changeme}}" />
        <property name="maximumPoolSize" value="${jdbc.pool.maximumPoolSize:10}" />
        <property name="minimumIdle" value="${jdbc.pool.minimumIdle:2}" />
        <property name="connectionTimeout" value="${jdbc.pool.connectionTimeoutMs:30000}" />
        <property name="initializationFailTimeout" value="${jdbc.pool.initializationFailTimeout:-1}" />
    </bean>

    <!-- Hibernate 6 SessionFactory (LocalSessionFactoryBean) scanning com.agriconnect.model -->
    <bean id="sessionFactory" class="org.springframework.orm.hibernate5.LocalSessionFactoryBean">
        <property name="dataSource" ref="dataSource" />
        <property name="packagesToScan" value="com.agriconnect.model" />
        <property name="hibernateProperties">
            <props>
                <prop key="hibernate.dialect">${hibernate.dialect:org.hibernate.dialect.MySQLDialect}</prop>
                <prop key="hibernate.hbm2ddl.auto">${spring.jpa.hibernate.ddl-auto:${hibernate.hbm2ddl.auto:validate}}</prop>
                <prop key="hibernate.show_sql">${hibernate.show_sql:false}</prop>
                <prop key="hibernate.format_sql">${hibernate.format_sql:false}</prop>
                <prop key="hibernate.use_sql_comments">false</prop>
                <prop key="hibernate.globally_quoted_identifiers">false</prop>
                <prop key="hibernate.connection.characterEncoding">utf8mb4</prop>
                <prop key="hibernate.connection.useUnicode">true</prop>
            </props>
        </property>
    </bean>

    <!-- HibernateTransactionManager -->
    <bean id="transactionManager" class="org.springframework.orm.hibernate5.HibernateTransactionManager">
        <property name="sessionFactory" ref="sessionFactory" />
    </bean>

    <!-- Enable @Transactional via <tx:annotation-driven> -->
    <tx:annotation-driven transaction-manager="transactionManager" />

</beans>
